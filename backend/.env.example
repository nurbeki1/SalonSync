# Telegram Bot Token (получить у @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Admin Chat ID (для уведомлений о новых мастерах)
ADMIN_CHAT_ID=your_admin_chat_id

# Database URL (по умолчанию SQLite)
DATABASE_URL=sqlite:///./app.db

# Kaspi Payment (номер телефона для приёма платежей)
KASPI_PHONE=77001234567

# CORS origins (через запятую)
FRONTEND_ORIGINS=http://localhost:3000,http://localhost:3001,https://salon-sync-psi.vercel.app